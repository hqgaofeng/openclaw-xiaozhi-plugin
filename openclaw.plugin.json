{
  "id": "xiaozhi",
  "name": "Xiaozhi Device Channel",
  "version": "0.4.0",
  "activation": {
    "onStartup": false
  },
  "channels": [
    "xiaozhi"
  ],
  "channelEnvVars": {
    "xiaozhi": [
      "XIAOZHI_AUTH_TOKEN"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "xiaozhi": {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "host": {
            "type": "string",
            "default": "0.0.0.0"
          },
          "port": {
            "type": "number",
            "default": 18790
          },
          "path": {
            "type": "string",
            "default": "/xiaozhi/v1/"
          },
          "tls": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": false
              },
              "cert": {
                "type": "string"
              },
              "key": {
                "type": "string"
              }
            }
          },
          "authTokens": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "globalAuthToken": {
            "type": "string"
          },
          "sessionIdPrefix": {
            "type": "string",
            "default": "xiaozhi"
          },
          "asr": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": [
                  "mock",
                  "sherpa_onnx",
                  "cloud"
                ]
              },
              "options": {
                "type": "object"
              }
            }
          },
          "tts": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": [
                  "mock",
                  "edge",
                  "minimax",
                  "cloud"
                ]
              },
              "options": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  }
}